# Backend origin used by the generated hey-api client.
# In dev, leave unset — Vite's proxy forwards /api → :5111 (see vite.config.ts).
# In prod, set this to the public API origin (e.g. https://api.iotd.app).
# VITE_API_URL=http://localhost:5111

# Sentry DSN. Empty (the default) means the SDK stays dormant —
# no init, no network. Set this only in production builds.
# VITE_SENTRY_DSN=

# Umami analytics — privacy-friendly, self-hosted. Both vars must be
# set to enable tracking; either one missing = no script, no network.
# Set in prod (and in any env where you want pageview / search /
# language-change / dispute-open signal).
# VITE_UMAMI_URL=https://analytics.iotd.app
# VITE_UMAMI_WEBSITE_ID=00000000-0000-0000-0000-000000000000
