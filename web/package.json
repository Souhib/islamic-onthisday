{
  "name": "thaqafa-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Thaqafa — web reading surface (Vite + React + TanStack)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "tsc -b --force && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "oxlint src --ignore-pattern src/api/generated",
    "lint:fix": "oxlint src --ignore-pattern src/api/generated --fix",
    "format": "oxfmt src",
    "format:check": "oxfmt src --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-api": "openapi-ts",
    "check": "bun run typecheck && bun run lint && bun run test"
  },
  "dependencies": {
    "@fontsource/amiri": "^5.2.8",
    "@hey-api/client-fetch": "^0.13.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@sentry/react": "^10.51.0",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.144.0",
    "clsx": "^2.1.1",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.6",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.0",
    "@tailwindcss/vite": "^4.1.0",
    "@tanstack/router-cli": "^1.166.38",
    "@tanstack/router-plugin": "^1.144.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^15.11.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
