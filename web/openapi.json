{"openapi": "3.1.0", "info": {"title": "Islamic On This Day", "description": "Read-only API serving one verified Islamic-history event per day, in both Hijri and Gregorian calendars. Backed by the data-pipeline's curated SQLite database.", "version": "0.1.0"}, "paths": {"/health": {"get": {"tags": ["system"], "summary": "Liveness + DB ping", "description": "Return the API health snapshot.", "operationId": "health_health_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HealthResponse"}}}}}}}, "/api/v1/today": {"get": {"tags": ["today"], "summary": "Headline event, secondary rails, observance for the current day", "description": "Return the Today payload for the current UTC day.\n\nA CDN can serve the same payload to thousands of readers in the same\ntime zone with one origin hit; the dependency stamps a Cache-Control\nthat expires at the next UTC midnight so the rollover is automatic.", "operationId": "get_today_api_v1_today_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TodayResponse"}}}}}}}, "/api/v1/events/{slug}": {"get": {"tags": ["events"], "summary": "Single-event detail by slug", "description": "Return the full event payload for ``slug``.", "operationId": "get_event_api_v1_events__slug__get", "parameters": [{"name": "slug", "in": "path", "required": true, "schema": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[a-z0-9][a-z0-9\\-]*$", "title": "Slug"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EventDetail"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/lessons": {"get": {"tags": ["lessons"], "summary": "List lessons with optional category filter", "description": "Paginated lesson list.", "operationId": "list_lessons_api_v1_lessons_get", "parameters": [{"name": "category", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string", "maxLength": 48}, {"type": "null"}], "description": "Filter by lesson category.", "title": "Category"}, "description": "Filter by lesson category."}, {"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "maximum": 100, "minimum": 1, "default": 30, "title": "Limit"}}, {"name": "offset", "in": "query", "required": false, "schema": {"type": "integer", "minimum": 0, "default": 0, "title": "Offset"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/LessonListResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/lessons/{slug}": {"get": {"tags": ["lessons"], "summary": "Single lesson detail by slug", "description": "Return the full lesson payload for ``slug``.", "operationId": "get_lesson_api_v1_lessons__slug__get", "parameters": [{"name": "slug", "in": "path", "required": true, "schema": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[a-z0-9][a-z0-9\\-]*$", "title": "Slug"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/LessonDetail"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/observances": {"get": {"tags": ["observances"], "summary": "List every recurring annual observance", "description": "Return every observance, ordered by Hijri month + day.", "operationId": "list_observances_api_v1_observances_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"items": {"$ref": "#/components/schemas/ObservanceDetail"}, "type": "array", "title": "Response List Observances Api V1 Observances Get"}}}}}}}, "/api/v1/observances/{slug}": {"get": {"tags": ["observances"], "summary": "Single observance by slug", "description": "Look up one observance.", "operationId": "get_observance_api_v1_observances__slug__get", "parameters": [{"name": "slug", "in": "path", "required": true, "schema": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9\\-]*$", "title": "Slug"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ObservanceDetail"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/people/{slug}": {"get": {"tags": ["people"], "summary": "Single-person detail by slug", "description": "Return the full person payload for ``slug``.", "operationId": "get_person_api_v1_people__slug__get", "parameters": [{"name": "slug", "in": "path", "required": true, "schema": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9\\-]*$", "title": "Slug"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PersonDetail"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/recent": {"get": {"tags": ["recent"], "summary": "Recent days \u2014 headline and observance for the last 7 calendar days", "description": "Return the Recent payload \u2014 the catch-up window.", "operationId": "get_recent_api_v1_recent_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RecentResponse"}}}}}}}, "/api/v1/upcoming": {"get": {"tags": ["upcoming"], "summary": "Upcoming days \u2014 headline + observance for the next N calendar days", "description": "Return the Upcoming payload \u2014 pre-fetch window for daily notifications.", "operationId": "get_upcoming_api_v1_upcoming_get", "parameters": [{"name": "days", "in": "query", "required": false, "schema": {"type": "integer", "maximum": 30, "minimum": 1, "description": "How many days to look ahead, starting today.", "default": 7, "title": "Days"}, "description": "How many days to look ahead, starting today."}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RecentResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/auth/signup": {"post": {"tags": ["auth"], "summary": "Create a new account and receive a token pair", "operationId": "signup_api_v1_auth_signup_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/SignupRequest"}}}, "required": true}, "responses": {"201": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TokenPair"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/auth/login": {"post": {"tags": ["auth"], "summary": "Exchange email + password for a token pair", "operationId": "login_api_v1_auth_login_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/LoginRequest"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TokenPair"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/auth/refresh": {"post": {"tags": ["auth"], "summary": "Exchange a refresh token for a fresh pair", "operationId": "refresh_api_v1_auth_refresh_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/RefreshRequest"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TokenPair"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/auth/me": {"get": {"tags": ["auth"], "summary": "Return the authenticated user's profile", "operationId": "me_api_v1_auth_me_get", "parameters": [{"name": "Authorization", "in": "header", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Authorization"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/UserPublic"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}, "patch": {"tags": ["auth"], "summary": "Update the authenticated user's display name", "operationId": "change_display_name_api_v1_auth_me_patch", "parameters": [{"name": "Authorization", "in": "header", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Authorization"}}], "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ChangeDisplayNameRequest"}}}}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/UserPublic"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}, "delete": {"tags": ["auth"], "summary": "Permanently delete the authenticated user's account", "description": "Permanently delete the authenticated user.\n\nCascades the user's bookmarks + every one-time-token row in a single\ntransaction. Idempotent \u2014 a re-tried delete on a token whose user is\nalready gone resolves to a no-op via the existing 401-on-missing-user\nflow.", "operationId": "delete_account_api_v1_auth_me_delete", "parameters": [{"name": "Authorization", "in": "header", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Authorization"}}], "responses": {"204": {"description": "Successful Response"}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/auth/password-reset/request": {"post": {"tags": ["auth"], "summary": "Send a password-reset email if the address is registered", "operationId": "request_password_reset_api_v1_auth_password_reset_request_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/PasswordResetRequest"}}}, "required": true}, "responses": {"204": {"description": "Successful Response"}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/auth/password-reset/confirm": {"post": {"tags": ["auth"], "summary": "Consume a password-reset token and set a new password", "operationId": "confirm_password_reset_api_v1_auth_password_reset_confirm_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/PasswordResetConfirm"}}}, "required": true}, "responses": {"204": {"description": "Successful Response"}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/auth/email/verify": {"post": {"tags": ["auth"], "summary": "Consume an email-verification token and mark the user verified", "operationId": "verify_email_api_v1_auth_email_verify_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/EmailVerifyConfirm"}}}, "required": true}, "responses": {"204": {"description": "Successful Response"}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/auth/email/resend": {"post": {"tags": ["auth"], "summary": "Re-send the verification email if the address is registered", "operationId": "resend_verification_email_api_v1_auth_email_resend_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/EmailVerifyResend"}}}, "required": true}, "responses": {"204": {"description": "Successful Response"}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/auth/me/password": {"post": {"tags": ["auth"], "summary": "Rotate the authenticated user's password", "operationId": "change_password_api_v1_auth_me_password_post", "parameters": [{"name": "Authorization", "in": "header", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Authorization"}}], "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ChangePasswordRequest"}}}}, "responses": {"204": {"description": "Successful Response"}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/auth/me/email": {"post": {"tags": ["auth"], "summary": "Start the email-change flow (verify link sent to the new address)", "operationId": "request_email_change_api_v1_auth_me_email_post", "parameters": [{"name": "Authorization", "in": "header", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Authorization"}}], "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ChangeEmailRequest"}}}}, "responses": {"204": {"description": "Successful Response"}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/auth/me/email/confirm": {"post": {"tags": ["auth"], "summary": "Consume an email-change token and apply the new address", "operationId": "confirm_email_change_api_v1_auth_me_email_confirm_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/ChangeEmailConfirm"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/UserPublic"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/bookmarks": {"get": {"tags": ["bookmarks"], "summary": "List the authenticated user's saved items", "operationId": "list_bookmarks_api_v1_bookmarks_get", "parameters": [{"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "maximum": 200, "minimum": 1, "default": 100, "title": "Limit"}}, {"name": "offset", "in": "query", "required": false, "schema": {"type": "integer", "minimum": 0, "default": 0, "title": "Offset"}}, {"name": "Authorization", "in": "header", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Authorization"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BookmarkList"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}, "post": {"tags": ["bookmarks"], "summary": "Save a new bookmark", "operationId": "create_bookmark_api_v1_bookmarks_post", "parameters": [{"name": "Authorization", "in": "header", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Authorization"}}], "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BookmarkCreate"}}}}, "responses": {"201": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BookmarkOut"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/bookmarks/{bookmark_id}": {"delete": {"tags": ["bookmarks"], "summary": "Delete one of the authenticated user's bookmarks", "operationId": "delete_bookmark_api_v1_bookmarks__bookmark_id__delete", "parameters": [{"name": "bookmark_id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid", "title": "Bookmark Id"}}, {"name": "Authorization", "in": "header", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Authorization"}}], "responses": {"204": {"description": "Successful Response"}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}}, "components": {"schemas": {"BookmarkCreate": {"properties": {"targetKind": {"type": "string", "enum": ["event", "lesson", "observance", "person"], "title": "Targetkind"}, "targetSlug": {"type": "string", "maxLength": 160, "minLength": 1, "pattern": "^[a-z0-9][a-z0-9\\-]*$", "title": "Targetslug"}, "note": {"anyOf": [{"type": "string", "maxLength": 512}, {"type": "null"}], "title": "Note"}}, "additionalProperties": false, "type": "object", "required": ["targetKind", "targetSlug"], "title": "BookmarkCreate", "description": "Inputs for ``POST /api/v1/bookmarks``."}, "BookmarkList": {"properties": {"items": {"items": {"$ref": "#/components/schemas/BookmarkOut"}, "type": "array", "title": "Items"}, "total": {"type": "integer", "title": "Total"}}, "additionalProperties": false, "type": "object", "required": ["items", "total"], "title": "BookmarkList", "description": "Paginated bookmarks payload."}, "BookmarkOut": {"properties": {"id": {"type": "string", "format": "uuid", "title": "Id"}, "targetKind": {"type": "string", "enum": ["event", "lesson", "observance", "person"], "title": "Targetkind"}, "targetSlug": {"type": "string", "title": "Targetslug"}, "targetTitle": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Targettitle"}, "targetTitleAr": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Targettitlear"}, "targetTitleFr": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Targettitlefr"}, "note": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Note"}, "createdAt": {"type": "string", "format": "date-time", "title": "Createdat"}}, "additionalProperties": false, "type": "object", "required": ["id", "targetKind", "targetSlug", "targetTitle", "targetTitleAr", "targetTitleFr", "note", "createdAt"], "title": "BookmarkOut", "description": "A single bookmark \u2014 what the saves list returns."}, "ChangeDisplayNameRequest": {"properties": {"displayName": {"type": "string", "maxLength": 64, "minLength": 1, "title": "Displayname"}}, "additionalProperties": false, "type": "object", "required": ["displayName"], "title": "ChangeDisplayNameRequest", "description": "Inputs for ``PATCH /api/v1/auth/me``."}, "ChangeEmailConfirm": {"properties": {"token": {"type": "string", "maxLength": 128, "minLength": 8, "title": "Token"}}, "additionalProperties": false, "type": "object", "required": ["token"], "title": "ChangeEmailConfirm", "description": "Inputs for ``POST /api/v1/auth/me/email/confirm`` \u2014 completes the flow."}, "ChangeEmailRequest": {"properties": {"currentPassword": {"type": "string", "maxLength": 128, "minLength": 1, "title": "Currentpassword"}, "newEmail": {"type": "string", "format": "email", "title": "Newemail"}}, "additionalProperties": false, "type": "object", "required": ["currentPassword", "newEmail"], "title": "ChangeEmailRequest", "description": "Inputs for ``POST /api/v1/auth/me/email`` \u2014 starts the change flow.\n\nThe password is required as a re-authentication step (the user is\nalready logged in but we want a fresh proof-of-ownership before\nmoving the email anywhere). The new email is the destination Resend\nsends the verification link to."}, "ChangePasswordRequest": {"properties": {"currentPassword": {"type": "string", "maxLength": 128, "minLength": 1, "title": "Currentpassword"}, "newPassword": {"type": "string", "maxLength": 128, "minLength": 8, "title": "Newpassword"}}, "additionalProperties": false, "type": "object", "required": ["currentPassword", "newPassword"], "title": "ChangePasswordRequest", "description": "Inputs for ``POST /api/v1/auth/me/password``."}, "DatasetSnapshot": {"properties": {"eventCount": {"type": "integer", "title": "Eventcount"}, "lessonCount": {"type": "integer", "title": "Lessoncount"}, "observanceCount": {"type": "integer", "title": "Observancecount"}, "personCount": {"type": "integer", "title": "Personcount"}, "builtAt": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Builtat"}, "ageHours": {"anyOf": [{"type": "number"}, {"type": "null"}], "title": "Agehours"}}, "additionalProperties": false, "type": "object", "required": ["eventCount", "lessonCount", "observanceCount", "personCount"], "title": "DatasetSnapshot", "description": "Per-resource row counts + dataset freshness signal.\n\n``built_at`` and ``age_hours`` come from the most recent ``updated_at``\non the ``events`` table \u2014 that's the signal that a pipeline rebuild\nactually happened, even when no rows were added or removed."}, "DisputedPosition": {"properties": {"rank": {"type": "integer", "title": "Rank"}, "value": {"type": "string", "title": "Value"}, "scholars": {"type": "string", "title": "Scholars"}, "weight": {"type": "string", "enum": ["primary", "notable", "minority"], "title": "Weight"}}, "additionalProperties":