# Environment selector. The matching .env.<value> file is loaded second and
# its keys win. .env.local (if present) wins last.
IOTD_ENV=development

# Application
HOST=127.0.0.1
PORT=5111

# Logging
LOG_LEVEL=DEBUG
LOG_SERIALIZE=false

# CORS — JSON array OR comma-separated origins both work.
CORS_ORIGINS=http://localhost:3000

# Database — defaults to the data-pipeline's SQLite file
# DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/islamic_onthisday.db

# Connection pool (ignored for sqlite)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=3600

# Auth — JWT signing. Production MUST set a real secret (32+ random bytes).
# JWT_SECRET_KEY=...
# ACCESS_TOKEN_MINUTES=30
# REFRESH_TOKEN_DAYS=30

# Email — Resend transactional API. Empty key = no-op (dev/test default).
# Put real keys in .env.local (gitignored), never .env.development.
# RESEND_API_KEY=re_...
# EMAIL_FROM_ADDRESS=noreply@majlisna.app
# EMAIL_FROM_NAME=Islamic On This Day
# FRONTEND_URL=http://localhost:3000
# PASSWORD_RESET_TOKEN_MINUTES=30
